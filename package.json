{
  "name": "coin-aggregator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "contracts:compile": "hardhat compile",
    "contracts:test": "hardhat test",
    "contracts:deploy:local": "hardhat run scripts/deploy-investment-vault.ts --network hardhat",
    "contracts:deploy:sepolia": "hardhat run scripts/deploy-investment-vault.ts --network sepolia",
    "contracts:verify:sepolia": "hardhat run scripts/verify-investment-vault.ts --network sepolia",
    "contracts:check": "npm run contracts:compile ; npm run contracts:test",
    "check": "npm run lint ; npm run build"
  },
  "dependencies": {
    "ethers": "^6.16.0",
    "framer-motion": "^12.34.3",
    "millify": "^6.1.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "viem": "^2.46.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chai": "^4.5.0",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "hardhat": "^2.26.3",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
